programa {
  funcao inicio() {
    inteiro temperatura[7], i, media=30,soma
 
 para(inteiro i=0; i<7;i++){
  escreva("Digite a temperatura:")
    leia(temperatura[i])
    soma=temperatura[i]*7/7

  }
  se(soma>media){
     escreva("acima da media")
  }
  senao{
  escreva("Na média ")
  }
 
 }
 
  }

